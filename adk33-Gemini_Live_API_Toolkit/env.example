# ══════════════════════════════════════════════════════════════════════════════
# MODELS
# ══════════════════════════════════════════════════════════════════════════════

MODEL=gemini-2.5-flash
RESEARCH_MODEL=gemini-2.5-pro

# ── Live API Model & Modality ─────────────────────────────────────────────────
#
# IMPORTANT — Model availability as of March 2026:
#   ✅ gemini-2.5-flash-preview-native-audio-dialog  → supports TEXT and AUDIO
#   ✅ gemini-2.5-flash-native-audio-preview-12-2025 → supports AUDIO only
#   ❌ gemini-live-2.5-flash          → SHUT DOWN (Dec 9 2025)
#   ❌ gemini-live-2.5-flash-preview  → SHUT DOWN (Dec 9 2025)
#   ❌ gemini-2.0-flash-live-001      → SHUT DOWN (Dec 9 2025)
#
# Option A: Half-cascade / dialog model — supports TEXT and AUDIO (recommended)
LIVE_MODEL=gemini-2.5-flash-preview-native-audio-dialog
LIVE_MODALITY=TEXT

# Option B: Native-audio model — AUDIO only (uncomment to use)
# LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# LIVE_MODALITY=AUDIO


# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE GENAI PLATFORM
# ══════════════════════════════════════════════════════════════════════════════

# 0 = Gemini Live API via Google AI Studio  (development  — API key auth)
# 1 = Vertex AI Live API via Google Cloud   (production   — GCP credential auth)
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_GENAI_API_VERSION=v1beta

# Vertex AI (only required when GOOGLE_GENAI_USE_VERTEXAI=1)
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT=modifi***-q0
PROJECT_ID=modifi***-q0


# ══════════════════════════════════════════════════════════════════════════════
# GEMINI — API KEY MODE  (GOOGLE_GENAI_USE_VERTEXAI=0)
# ══════════════════════════════════════════════════════════════════════════════

GOOGLE_API_KEY=AIzaSy***JlN-C54
GOOGLE_CSE_ID=370***a13
GOOGLE_MAPS_API_KEY=AIzaSyAbI***2gv2OgvM


# ══════════════════════════════════════════════════════════════════════════════
# GCS ARTIFACT SERVICE
