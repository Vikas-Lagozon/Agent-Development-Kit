```python
#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import requests
import csv
from bs4 import BeautifulSoup

def scrape_myntra(search_query):
    """
    Scrapes product data from Myntra for a given search query.
    """
    query_formatted = search_query.replace(' ', '-')
    url = f"https://www.myntra.com/{query_formatted}"
    
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
    }

    print(f"Sending request to: {url}")
    response = requests.get(url, headers=headers)

    if response.status_code != 200:
        print(f"Failed to retrieve the page. Status code: {response.status_code}")
        return

    soup = BeautifulSoup(response.content, 'html.parser')
    
    # Myntra uses a specific class for product containers
    products = soup.find_all('li', class_='product-base')

    if not products:
        print("No products found. The page structure might have changed or the query returned no results.")
        return

    products_data = []

    for product in products:
        brand_tag = product.find('h3', class_='product-brand')
        description_tag = product.find('h4', class_='product-product')
        price_info = product.find('div', class_='product-price')
        
        # Skip if essential info is missing
        if not all([brand_tag, description_tag, price_info]):
            continue

        brand = brand_tag.get_text(strip=True)
        description = description_tag.get_text(strip=True)
        
        # Extract price details
        current_price_tag = price_info.find('span')
        original_price_tag = price_info.find('span', class_='product-strike')
        discount_tag = product.find('span', class_='product-discountPercentage')

        current_price = current_price_tag.get_text(strip=True) if current_price_tag else 'N/A'
        original_price = original_price_tag.get_text(strip=True) if original_price_tag else current_price
        discount = discount_tag.get_text(strip=True) if discount_tag else 'No Discount'

        products_data.append({
            'Brand': brand,
            'Description': description,
            'Current Price': current_price,
            'Original Price': original_price,
            'Discount': discount
        })

    if not products_data:
        print("Could not extract any product data.")
        return

    # Save data to CSV
    filename = 'myntra_products.csv'
    with open(filename, 'w', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=products_data[0].keys())
        writer.writeheader()
        writer.writerows(products_data)
    
    print(f"Successfully scraped {len(products_data)} products.")
    print(f"Data saved to {filename}")


if __name__ == "__main__":
    # Example search query
    query = "shirts for men"
    scrape_myntra(query)
```
