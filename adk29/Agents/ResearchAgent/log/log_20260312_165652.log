```python
import requests
from bs4 import BeautifulSoup
import csv
import re

def scrape_myntra_products(search_query):
    """
    Scrapes product data from a Myntra search results page.

    Args:
        search_query (str): The product to search for (e.g., "tshirts for men").

    Returns:
        list: A list of dictionaries, where each dictionary contains
              details of a product (brand, description, price).
              Returns an empty list if the request fails or no products are found.
    """
    # Format the search query for the URL. Myntra uses '-' for spaces.
    formatted_query = search_query.replace(" ", "-")
    url = f"https://www.myntra.com/{formatted_query}"

    # Headers are important to mimic a browser and avoid being blocked.
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
    }

    print(f"Sending request to: {url}")
    try:
        # Send an HTTP GET request to the URL
        response = requests.get(url, headers=headers, timeout=10)
        # Raise an exception for bad status codes (like 404 or 500)
        response.raise_for_status()
    except requests.exceptions.RequestException as e:
        print(f"Error during request: {e}")
        return []

    # Parse the HTML content of the page
    soup = BeautifulSoup(response.content, 'html.parser')

    # Find all product containers.
    # Note: Website class names can change over time. This is based on the current structure.
    # If the script fails, inspect the page source to find the new class names.
    products = soup.find_all('li', class_='product-base')

    if not products:
        print("No product containers found. The website structure may have changed.")
        return []

    scraped_data = []
    print(f"Found {len(products)} products. Extracting data...")

    for product in products:
        # Using .get_text() with strip=True to clean up extra whitespace
        brand_element = product.find('h3', class_='product-brand')
        brand = brand_element.get_text(strip=True) if brand_element else 'N/A'

        description_element = product.find('h4', class_='product-product')
        description = description_element.get_text(strip=True) if description_element else 'N/A'

        price_element = product.find('div', class_='product-price')
        price_text = price_element.get_text(strip=True) if price_element else 'N/A'
        
        # Prices can be complex (e.g., "Rs. 599Rs. 999(40% OFF)").
        # We use regex to extract the current selling price.
        price_match = re.search(r'Rs\.\s*([\d,]+)', price_text)
        price = price_match.group(1).replace(',', '') if price_match else 'N/A'

        scraped_data.append({
            'brand': brand,
            'description': description,
            'price': price
        })

    return scraped_data

def save_to_csv(data, filename="myntra_products.csv"):
    """
    Saves a list of product data to a CSV file.

    Args:
        data (list): A list of product dictionaries.
        filename (str): The name of the CSV file to create.
    """
    if not data:
        print("No data to save.")
        return

    # The headers for the CSV will be the keys from the first dictionary
    headers = data[0].keys()

    try:
        with open(filename, 'w', newline='', encoding='utf-8') as csvfile:
            writer = csv.DictWriter(csvfile, fieldnames=headers)
            writer.writeheader()
            writer.writerows(data)
        print(f"Data successfully saved to {filename}")
    except IOError as e:
        print(f"Error writing to file {filename}: {e}")

if __name__ == "__main__":
    # --- Instructions for use ---
    # 1. Make sure you have the required libraries:
    #    pip install requests beautifulsoup4
    # 2. Change the `search_term` variable to what you want to scrape.
    
    search_term = "tshirts for men"
    product_data = scrape_myntra_products(search_term)

    if product_data:
        # Print the first 5 results for a quick check in the console
        print("\n--- First 5 Products Scraped ---")
        for item in product_data[:5]:
            print(item)
        print("--------------------------------\n")
        
        # Save all results to a CSV file
        output_filename = f"myntra_{search_term.replace(' ', '_')}.csv"
        save_to_csv(product_data, filename=output_filename)

```
